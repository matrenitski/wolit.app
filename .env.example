# --- wolit.app configuration ---
# Copy this file to `.env.local` and fill in your values.

# Google OAuth 2.0 Client ID (type: "Web application").
# This value is PUBLIC and safe to expose in a static site — it is NOT a secret.
# Create one at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Which Bitcoin network to use:
#   testnet = play money, free coins from a faucet (recommended while building)
#   mainnet = real Bitcoin
VITE_BITCOIN_NETWORK=testnet
